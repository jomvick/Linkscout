# Port d'écoute (défaut: 8001)
PORT=8001

# CORS — comma-separated allowed origins (défaut: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Apify — pour le scraping cloud
APIFY_TOKEN=your_apify_token

# Groq — analyse IA des offres
GROQ_API_KEY=gsk_your_groq_key

# Supabase 
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key           # Pour validation JWT Auth
SUPABASE_SERVICE_KEY=your-service-role-key # Pour écriture jobs (bypass RLS)

# Discord webhook (optionnel — alertes match > 90%)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
