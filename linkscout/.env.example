# ── Supabase (public — côté navigateur, Realtime + CRUD) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Rust unified backend URL (scrape, analyze, message, enrich) ──────────
NEXT_PUBLIC_WORKER_URL=http://localhost:8001

# ── Clé API Groq — utilisée par /api/intent pour convertir le langage ────
#     naturel en mots-clés de recherche LinkedIn.
GROQ_API_KEY=gsk_your_groq_key

# ── Clé service Supabase — utilisée côté serveur pour les opérations ────
#     nécessitant un bypass RLS (ex: /api/alerts, /api/resume).
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Clé API interne — partagée entre le worker Rust et les routes ───────
#     Next.js pour les opérations automatisées (ex: auto-confirm, auto-add
#     en collection). Doit correspondre à la valeur côté worker.
INTERNAL_API_KEY=your-internal-api-key
